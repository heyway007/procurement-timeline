DATABASE_URL="postgresql://user:password@host:5432/timeline?sslmode=require"
TEST_DATABASE_URL="postgresql://user:password@host:5432/timeline_test?sslmode=require"
HOLIDAY_PREVIEW_SECRET="replace-with-a-long-random-secret"

# Backend storage mode: postgres (default) or google_drive.
STORAGE_MODE="postgres"

# Google Drive storage mode stores all data in one JSON file.
# Create a Google Cloud service account, share the target file/folder with
# GOOGLE_DRIVE_CLIENT_EMAIL, then set STORAGE_MODE="google_drive".
GOOGLE_DRIVE_CLIENT_EMAIL="timeline-service@example.iam.gserviceaccount.com"
GOOGLE_DRIVE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-with-private-key\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_FILE_ID=""
GOOGLE_DRIVE_FOLDER_ID=""
GOOGLE_DRIVE_FILE_NAME="procurement-timeline-data.json"
