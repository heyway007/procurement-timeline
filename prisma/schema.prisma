generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ScheduleStatus {
  NORMAL
  NEEDS_REVIEW
}

enum HolidayScope {
  NATIONWIDE
  BANGKOK
}

enum HolidayOrigin {
  MANUAL
  OFFICIAL_SYNC
}

enum HolidaySyncStatus {
  FRESH
  CACHED
  FAILED
}

model Template {
  id        String         @id @default(uuid()) @db.Uuid
  key       String         @unique
  name      String
  version   Int
  steps     TemplateStep[]
  projects  Project[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model TemplateStep {
  id                String   @id @default(uuid()) @db.Uuid
  templateId        String   @db.Uuid
  order             Int
  label             String
  workingDaysToNext Int
  template          Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, order])
  @@index([templateId])
}

model Project {
  id                           String         @id @default(uuid()) @db.Uuid
  name                         String
  ownerName                    String
  budget                       Decimal        @db.Decimal(15, 2)
  startDate                    DateTime       @db.Date
  note                         String?
  templateId                   String         @db.Uuid
  templateVersion              Int
  processEndDate               DateTime       @db.Date
  isProcessEndManuallyAdjusted Boolean        @default(false)
  scheduleStatus               ScheduleStatus @default(NORMAL)
  version                      Int            @default(1)
  createdAt                    DateTime       @default(now())
  updatedAt                    DateTime       @updatedAt
  template                     Template       @relation(fields: [templateId], references: [id], onDelete: Restrict)
  steps                        ProjectStep[]

  @@index([name])
  @@index([ownerName])
  @@index([startDate, processEndDate])
}

model ProjectStep {
  id                     String   @id @default(uuid()) @db.Uuid
  projectId              String   @db.Uuid
  order                  Int
  label                  String
  workingDaysToNext      Int
  scheduledDate          DateTime @db.Date
  isDateManuallyAdjusted Boolean  @default(false)
  project                Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, order])
  @@index([projectId])
  @@index([scheduledDate])
}

model Holiday {
  id                  String        @id @default(uuid()) @db.Uuid
  date                DateTime      @unique @db.Date
  name                String
  sourceNote          String
  scope               HolidayScope  @default(NATIONWIDE)
  origin              HolidayOrigin @default(MANUAL)
  officialSourceUrl   String?
  officialSourceLabel String?
  lastConfirmedAt     DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model HolidayCalendarYear {
  year               Int       @id
  isVerifiedComplete Boolean   @default(false)
  sourceNote         String
  verifiedAt         DateTime?
  lastSyncAttemptAt  DateTime?
  lastSuccessfulSyncAt DateTime?
  lastSyncStatus     HolidaySyncStatus?
  lastSyncMessage    String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}
